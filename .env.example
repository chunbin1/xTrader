# LLM Provider 配置
# 可选: mimo / zhipu / openai
LLM_PROVIDER=mimo
# 主模型（留空则使用 provider 默认模型）
LLM_MODEL=

# Xiaomi MiMo API Key (https://platform.xiaomimimo.com/#/console/api-keys)
MIMO_API_KEY=your_mimo_api_key_here

# 智谱 AI API Key (https://bigmodel.cn -> 控制台 -> API Keys)
ZHIPU_API_KEY=your_zhipu_api_key_here

# 飞书自定义机器人 Webhook 地址
# 在飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token_here

# 飞书签名校验密钥（可选，机器人开启签名校验时填写）
FEISHU_SECRET=

# 监控间隔（秒），默认 120 秒
POLL_INTERVAL=120

# Truth Social RSS 地址
RSS_URL=https://trumpstruth.org/feed

# X (Twitter) Cookie - 用于抓取推文
# 获取方式：浏览器登录 x.com → F12 → 应用 → Cookie → x.com
X_AUTH_TOKEN=your_auth_token_here
X_CT0=your_ct0_here

# 免打扰时段（北京时间），格式 HH:MM-HH:MM，留空表示全天推送
QUIET_HOURS=02:00-07:00

# Twelve Data API Key（实时行情，twelvedata.com）
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
