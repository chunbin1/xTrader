# 智谱 AI API Key (https://bigmodel.cn -> 控制台 -> API Keys)
ZHIPU_API_KEY=your_zhipu_api_key_here

# 使用的模型（可选，默认 glm-4-flash）
# 可选: glm-4-flash / glm-4-plus / glm-4-air / glm-4-long / glm-z1-flash 等
ZHIPU_MODEL=glm-4-flash

# 飞书自定义机器人 Webhook 地址
# 在飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token_here

# 飞书签名校验密钥（可选，机器人开启签名校验时填写）
FEISHU_SECRET=

# 监控间隔（秒），默认 60 秒
POLL_INTERVAL=60

# Truth Social RSS 地址（默认已填好）
RSS_URL=https://trumpstruth.org/feed
